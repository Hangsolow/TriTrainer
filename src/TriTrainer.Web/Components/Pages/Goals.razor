@page "/goals"
@rendermode InteractiveServer
@inject ActivityApiClient ApiClient

<PageTitle>Goals</PageTitle>

<h1 class="page-title">Goals</h1>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<section class="surface-card mb-4">
    <h2>Create Goal</h2>
    <div class="row g-2">
        <div class="col-md-3">
            <label class="form-label">Goal Type</label>
            <select class="form-select" @bind="goalType">
                @foreach (var value in Enum.GetValues<GoalType>())
                {
                    <option value="@value">@value</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Discipline</label>
            <select class="form-select" @bind="disciplineSelection">
                <option value="">Any</option>
                @foreach (var value in Enum.GetValues<ActivityType>())
                {
                    <option value="@value">@value</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label">Target Value</label>
            <input class="form-control" type="number" step="0.1" @bind="targetValue" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Target Date</label>
            <input class="form-control" type="date" @bind="targetDate" />
        </div>
    </div>

    <div class="form-check mt-3">
        <input id="quickStartPlan" class="form-check-input" type="checkbox" @bind="quickStartPlanEnabled" />
        <label class="form-check-label" for="quickStartPlan">Quick start: create a starter plan after creating this goal</label>
    </div>

    @if (quickStartPlanEnabled)
    {
        <div class="row g-2 mt-1">
            <div class="col-md-4">
                <label class="form-label">Starter Plan Name</label>
                <input class="form-control" @bind="quickStartPlanName" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Plan Start Date</label>
                <input class="form-control" type="date" @bind="quickStartStartDate" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Weeks (4-16)</label>
                <input class="form-control" type="number" min="4" max="16" @bind="quickStartWeekCount" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Activation</label>
                <div class="form-check mt-2">
                    <input id="activatePlanNow" class="form-check-input" type="checkbox" @bind="activatePlanAfterCreation" />
                    <label class="form-check-label" for="activatePlanNow">Activate plan immediately</label>
                </div>
            </div>
        </div>
        <p class="text-muted small mt-2 mb-0">Defaults are prefilled to reduce setup friction and keep the plan within your target date.</p>
    }

    <button class="btn btn-primary mt-3" @onclick="CreateGoal">Create Goal</button>
</section>

<section class="surface-card">
    <h2>Goal List</h2>

    @if (isLoading)
    {
        <p class="text-muted">Loading goals...</p>
    }
    else if (goals.Count == 0)
    {
        <p class="text-muted">No goals yet.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Discipline</th>
                        <th>Target Date</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var goal in goals)
                    {
                        <tr>
                            <td>@goal.GoalType</td>
                            <td>@(goal.Discipline?.ToString() ?? "Any")</td>
                            <td>@goal.TargetDate.ToString("yyyy-MM-dd")</td>
                            <td>@goal.Status</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-success" disabled="@(goal.Status == GoalStatus.Active)" @onclick="() => UpdateStatus(goal.Id, GoalStatus.Active)">Activate</button>
                                    <button class="btn btn-outline-secondary" disabled="@(goal.Status == GoalStatus.Archived)" @onclick="() => UpdateStatus(goal.Id, GoalStatus.Archived)">Archive</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private string? successMessage;
    private List<Goal> goals = [];

    private GoalType goalType = GoalType.EventFinish;
    private string? disciplineSelection;
    private decimal? targetValue;
    private DateTime targetDate = DateTime.Today.AddDays(90);
    private bool quickStartPlanEnabled = true;
    private string quickStartPlanName = "Starter Build";
    private DateTime quickStartStartDate = GetNextMonday(DateTime.Today);
    private int quickStartWeekCount = 8;
    private bool activatePlanAfterCreation = true;

    protected override async Task OnInitializedAsync()
    {
        await EnsureProfileAsync();
        await LoadGoalsAsync();
    }

    private async Task LoadGoalsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            goals = await ApiClient.GetGoalsAsync();
        }
        catch
        {
            // Absorb brief startup/readiness blips before surfacing an error.
            try
            {
                await Task.Delay(250);
                goals = await ApiClient.GetGoalsAsync();
                errorMessage = null;
            }
            catch (Exception ex)
            {
                errorMessage = $"Failed to load goals: {ex.Message}";
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateGoal()
    {
        errorMessage = null;
        successMessage = null;

        var parsedTargetDate = DateOnly.FromDateTime(targetDate.Date);

        if (parsedTargetDate <= DateOnly.FromDateTime(DateTime.Today))
        {
            errorMessage = "Target date must be in the future.";
            return;
        }

        var discipline = string.IsNullOrWhiteSpace(disciplineSelection)
            ? (ActivityType?)null
            : Enum.Parse<ActivityType>(disciplineSelection);

        if (quickStartPlanEnabled)
        {
            if (string.IsNullOrWhiteSpace(quickStartPlanName))
            {
                errorMessage = "Starter plan name is required when quick start is enabled.";
                return;
            }

            if (quickStartWeekCount is < 4 or > 16)
            {
                errorMessage = "Starter plan week count must be between 4 and 16.";
                return;
            }

            var quickStartDateOnly = DateOnly.FromDateTime(quickStartStartDate.Date);
            if (quickStartDateOnly < DateOnly.FromDateTime(DateTime.Today))
            {
                errorMessage = "Starter plan start date cannot be in the past.";
                return;
            }

            var quickStartEnd = quickStartDateOnly.AddDays((quickStartWeekCount * 7) - 1);
            if (quickStartEnd > parsedTargetDate)
            {
                errorMessage = "Starter plan end date must be on or before the goal target date. Reduce weeks or move the start date earlier.";
                return;
            }
        }

        try
        {
            if (quickStartPlanEnabled)
            {
                var quickStartDateOnly = DateOnly.FromDateTime(quickStartStartDate.Date);

                var quickStartResult = await ApiClient.CreateQuickStartGoalAsync(new CreateQuickStartGoalRequest(
                    goalType,
                    discipline,
                    targetValue,
                    parsedTargetDate,
                    quickStartPlanName.Trim(),
                    quickStartDateOnly,
                    quickStartWeekCount,
                    activatePlanAfterCreation));

                if (quickStartResult is null)
                {
                    errorMessage = "Quick start did not return goal or plan details.";
                    return;
                }

                successMessage = activatePlanAfterCreation
                    ? "Goal, starter plan, and activation completed."
                    : "Goal and starter plan created.";
            }
            else
            {
                var createdGoal = await ApiClient.CreateGoalAsync(new CreateGoalRequest(goalType, discipline, targetValue, parsedTargetDate));
                if (createdGoal is null)
                {
                    errorMessage = "Goal creation did not return data.";
                    return;
                }

                successMessage = "Goal created.";
            }

            RecomputeQuickStartDefaults();
            await LoadGoalsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = quickStartPlanEnabled
                ? $"Failed to create goal + starter plan: {ex.Message}"
                : $"Failed to create goal: {ex.Message}";
        }
    }

    private async Task UpdateStatus(Guid goalId, GoalStatus status)
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            await ApiClient.UpdateGoalStatusAsync(goalId, status);
            await LoadGoalsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to update goal status: {ex.Message}";
        }
    }

    private void RecomputeQuickStartDefaults()
    {
        quickStartStartDate = GetNextMonday(DateTime.Today);
        quickStartWeekCount = SuggestWeekCount(DateOnly.FromDateTime(targetDate.Date), DateOnly.FromDateTime(quickStartStartDate.Date));

        var disciplineLabel = string.IsNullOrWhiteSpace(disciplineSelection) ? "Tri" : disciplineSelection;
        quickStartPlanName = $"{disciplineLabel} {goalType} Build";
    }

    private static int SuggestWeekCount(DateOnly target, DateOnly start)
    {
        var days = target.DayNumber - start.DayNumber + 1;
        if (days <= 0)
        {
            return 4;
        }

        var computed = days / 7;
        return Math.Clamp(computed, 4, 16);
    }

    private static DateTime GetNextMonday(DateTime from)
    {
        var date = from.Date;
        var daysUntilMonday = ((int)DayOfWeek.Monday - (int)date.DayOfWeek + 7) % 7;
        return date.AddDays(daysUntilMonday == 0 ? 7 : daysUntilMonday);
    }

    private async Task EnsureProfileAsync()
    {
        var profile = await ApiClient.GetAthleteProfileAsync();
        if (profile is null)
        {
            await ApiClient.UpsertAthleteProfileAsync(new UpsertAthleteProfileRequest(
                "Triathlete",
                8,
                DateOnly.FromDateTime(DateTime.Today).AddDays(120)));
        }

        RecomputeQuickStartDefaults();
    }
}
