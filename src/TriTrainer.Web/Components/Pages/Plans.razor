@page "/plans"
@rendermode InteractiveServer
@inject ActivityApiClient ApiClient

<PageTitle>Plans</PageTitle>

<h1 class="page-title">Plans</h1>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<section class="surface-card mb-4">
    <h2>Create Plan</h2>
    <div class="row g-2">
        <div class="col-md-3">
            <label class="form-label">Goal</label>
            <select class="form-select" @bind="selectedGoalId">
                <option value="">Select goal</option>
                @foreach (var goal in goals)
                {
                    <option value="@goal.Id">@goal.GoalType – @goal.TargetDate.ToString("yyyy-MM-dd") (@goal.Status)</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Name</label>
            <input class="form-control" @bind="planName" placeholder="e.g. Base Build Block" />
        </div>
        <div class="col-md-3">
            <label class="form-label">Start Date</label>
            <input class="form-control" type="date" @bind="startDate" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Weeks (4–16)</label>
            <input class="form-control" type="number" min="4" max="16" @bind="weekCount" />
        </div>
    </div>
    <p class="text-muted small mt-2 mb-0">Sessions are auto-generated from your goal type and weekly hours.</p>
    <button class="btn btn-primary mt-3" @onclick="CreatePlan">Create Plan</button>
</section>

<section class="surface-card">
    <h2>Plan List</h2>

    @if (isLoading)
    {
        <p class="text-muted">Loading plans...</p>
    }
    else if (plans.Count == 0)
    {
        <p class="text-muted">No plans yet.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Status</th>
                        <th>Range</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var plan in plans)
                    {
                        <tr>
                            <td><strong>@plan.Name</strong></td>
                            <td><span class="tt-plan-status tt-plan-@plan.Status.ToString().ToLower()">@plan.Status</span></td>
                            <td class="text-muted small">@plan.StartDate.ToString("yyyy-MM-dd") → @plan.EndDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-secondary" @onclick="() => LoadPlan(plan.Id)">Details</button>
                                    <a class="btn btn-outline-primary" href="@($"progress?planId={plan.Id}&weekStart={plan.StartDate:yyyy-MM-dd}")">Progress</a>
                                    @if (plan.Status == PlanStatus.Draft)
                                    {
                                        <button class="btn btn-outline-success" @onclick="() => ActivatePlan(plan.Id)">Activate</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@if (selectedPlan is not null)
{
    <section class="surface-card mt-4">
        <div class="d-flex align-items-center gap-2 mb-3">
            <h2 class="mb-0">@selectedPlan.Name</h2>
            <span class="tt-plan-status tt-plan-@selectedPlan.Status.ToString().ToLower()">@selectedPlan.Status</span>
            <span class="text-muted small ms-auto">@selectedPlan.Weeks.Count weeks · @selectedPlan.Weeks.Sum(w => w.Sessions.Count) sessions · @selectedPlan.Weeks.Sum(w => w.Sessions.Sum(s => s.PlannedDurationMinutes)) min planned</span>
        </div>

        @foreach (var week in selectedPlan.Weeks.OrderBy(w => w.WeekIndex))
        {
            var weekTotalMin = week.Sessions.Sum(s => s.PlannedDurationMinutes);
            <div class="mb-2 p-3 border rounded bg-white">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <strong>Week @week.WeekIndex <span class="text-muted fw-normal small">(@week.WeekStartDate.ToString("MMM d, yyyy"))</span></strong>
                    <div class="d-flex align-items-center gap-3">
                        @if (week.Sessions.Count > 0)
                        {
                            <span class="text-muted small">@week.Sessions.Count session@(week.Sessions.Count == 1 ? "" : "s") · @weekTotalMin min</span>
                        }
                        <a class="btn btn-sm btn-outline-primary" href="@($"progress?planId={selectedPlan.Id}&weekStart={week.WeekStartDate:yyyy-MM-dd}")">Progress</a>
                    </div>
                </div>
                @if (week.Sessions.Count == 0)
                {
                    <p class="text-muted mb-0">No planned sessions.</p>
                }
                else
                {
                    <div class="tt-session-list">
                        @foreach (var session in week.Sessions.OrderBy(s => s.DayOfWeek))
                        {
                            <div class="tt-session-pill">
                                <span>@DisciplineIcon(session.Discipline)</span>
                                <span class="tt-session-discipline">@session.Discipline</span>
                                <span class="tt-session-type-badge tt-session-@session.SessionType.ToString().ToLower()">@session.SessionType</span>
                                <span class="text-muted small">@session.DayOfWeek</span>
                                <span class="tt-session-duration">@session.PlannedDurationMinutes min</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </section>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;

    private List<Goal> goals = [];
    private List<PlanSummary> plans = [];
    private PlanDetail? selectedPlan;

    private string? selectedGoalId;
    private string planName = "Base Build";
    private DateTime startDate = DateTime.Today;
    private int weekCount = 4;

    protected override async Task OnInitializedAsync()
    {
        await EnsureProfileAsync();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            goals = await ApiClient.GetGoalsAsync();
            plans = await ApiClient.GetPlansAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load plans data: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreatePlan()
    {
        errorMessage = null;

        if (!Guid.TryParse(selectedGoalId, out var goalId))
        {
            errorMessage = "Please select a goal before creating a plan.";
            return;
        }

        try
        {
            await ApiClient.CreatePlanAsync(new CreatePlanRequest(goalId, planName, DateOnly.FromDateTime(startDate.Date), weekCount));
            selectedPlan = null;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to create plan: {ex.Message}";
        }
    }

    private async Task LoadPlan(Guid id)
    {
        errorMessage = null;

        try
        {
            selectedPlan = await ApiClient.GetPlanAsync(id);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load plan details: {ex.Message}";
        }
    }

    private async Task ActivatePlan(Guid id)
    {
        errorMessage = null;

        try
        {
            await ApiClient.UpdatePlanStatusAsync(id, PlanStatus.Active);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to activate plan: {ex.Message}";
        }
    }

    private async Task EnsureProfileAsync()
    {
        var profile = await ApiClient.GetAthleteProfileAsync();
        if (profile is null)
        {
            await ApiClient.UpsertAthleteProfileAsync(new UpsertAthleteProfileRequest(
                "Triathlete",
                8,
                DateOnly.FromDateTime(DateTime.Today).AddDays(120)));
        }
    }

    private static string DisciplineIcon(ActivityType discipline) => discipline switch
    {
        ActivityType.Run   => "🏃",
        ActivityType.Cycle => "🚴",
        ActivityType.Swim  => "🏊",
        _                  => "•"
    };
}

