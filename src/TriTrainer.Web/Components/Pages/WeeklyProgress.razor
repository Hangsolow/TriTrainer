@page "/progress"
@rendermode InteractiveServer
@inject ActivityApiClient ApiClient

<PageTitle>Weekly Progress</PageTitle>

<h1 class="page-title">Weekly Progress</h1>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<section class="surface-card mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-6">
            <label class="form-label">Plan</label>
            <select class="form-select" @bind="selectedPlanId">
                <option value="">Select plan</option>
                @foreach (var plan in plans)
                {
                    <option value="@plan.Id">@plan.Name (@plan.Status)</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Week Start</label>
            <input class="form-control" type="date" @bind="weekStartDate" />
        </div>
        <div class="col-md-2">
            <button class="btn btn-primary w-100" @onclick="LoadProgress">Load</button>
        </div>
    </div>
</section>

@if (isLoading)
{
    <p class="text-muted">Loading progress...</p>
}
else if (progress is null)
{
    <p class="text-muted">Select a plan and week to view progress.</p>
}
else
{
    var activeDisciplines = progress.Disciplines
        .Where(d => d.PlannedMinutes > 0 || d.CompletedMinutes > 0)
        .ToList();
    var totalVariance = progress.Totals.CompletedMinutes - progress.Totals.PlannedMinutes;

    <section class="surface-card">
        <div class="d-flex align-items-center gap-3 mb-3">
            <h2 class="mb-0">Week of @progress.WeekStartDate.ToString("MMM d, yyyy")</h2>
            <span class="tt-compliance-badge @ComplianceBadgeClass(progress.Totals.CompliancePercent)">
                @progress.Totals.CompliancePercent% overall
            </span>
        </div>

        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Discipline</th>
                        <th>Planned</th>
                        <th>Completed</th>
                        <th>Variance</th>
                        <th>Compliance</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in activeDisciplines)
                    {
                        var variance = row.CompletedMinutes - row.PlannedMinutes;
                        <tr>
                            <td>@DisciplineIcon(row.Discipline) <strong>@row.Discipline</strong></td>
                            <td>@row.PlannedMinutes min</td>
                            <td>@row.CompletedMinutes min</td>
                            <td class="@VarianceClass(variance)">@FormatVariance(variance)</td>
                            <td class="@ComplianceClass(row.CompliancePercent)">@row.CompliancePercent%</td>
                        </tr>
                    }
                    @if (activeDisciplines.Count == 0)
                    {
                        <tr><td colspan="5" class="text-muted">No planned or completed sessions this week.</td></tr>
                    }
                </tbody>
                <tfoot>
                    <tr class="table-light">
                        <th>Total</th>
                        <th>@progress.Totals.PlannedMinutes min</th>
                        <th>@progress.Totals.CompletedMinutes min</th>
                        <th class="@VarianceClass(totalVariance)">@FormatVariance(totalVariance)</th>
                        <th class="@ComplianceClass(progress.Totals.CompliancePercent)">@progress.Totals.CompliancePercent%</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </section>
}

@code {
    [SupplyParameterFromQuery(Name = "planId")]
    public Guid? PlanId { get; set; }

    [SupplyParameterFromQuery(Name = "weekStart")]
    public string? WeekStart { get; set; }

    private bool isLoading = true;
    private string? errorMessage;

    private List<PlanSummary> plans = [];
    private WeeklyProgressResponse? progress;

    private string? selectedPlanId;
    private DateTime weekStartDate = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await EnsureProfileAsync();

        plans = await ApiClient.GetPlansAsync();
        selectedPlanId = PlanId?.ToString() ?? plans.FirstOrDefault()?.Id.ToString();

        if (!string.IsNullOrWhiteSpace(WeekStart) && DateTime.TryParse(WeekStart, out var parsedWeekStart))
        {
            weekStartDate = parsedWeekStart.Date;
        }
        else if (plans.Count > 0)
        {
            weekStartDate = plans[0].StartDate.ToDateTime(TimeOnly.MinValue);
        }

        await LoadProgress();
    }

    private async Task LoadProgress()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            if (!Guid.TryParse(selectedPlanId, out var planId))
            {
                progress = null;
                return;
            }

            var weekStart = DateOnly.FromDateTime(weekStartDate.Date);
            progress = await ApiClient.GetWeeklyProgressAsync(planId, weekStart);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load weekly progress: {ex.Message}";
            progress = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task EnsureProfileAsync()
    {
        var profile = await ApiClient.GetAthleteProfileAsync();
        if (profile is null)
        {
            await ApiClient.UpsertAthleteProfileAsync(new UpsertAthleteProfileRequest(
                "Triathlete",
                8,
                DateOnly.FromDateTime(DateTime.Today).AddDays(120)));
        }
    }

    private static string DisciplineIcon(ActivityType discipline) => discipline switch
    {
        ActivityType.Run   => "🏃",
        ActivityType.Cycle => "🚴",
        ActivityType.Swim  => "🏊",
        _                  => ""
    };

    private static string ComplianceClass(decimal pct) =>
        pct >= 90 ? "tt-compliance-good" : pct >= 70 ? "tt-compliance-ok" : "tt-compliance-low";

    private static string ComplianceBadgeClass(decimal pct) =>
        pct >= 90 ? "tt-compliance-badge-good" : pct >= 70 ? "tt-compliance-badge-ok" : "tt-compliance-badge-low";

    private static string VarianceClass(int variance) =>
        variance > 0 ? "tt-variance-positive" : variance < 0 ? "tt-variance-negative" : "tt-variance-neutral";

    private static string FormatVariance(int variance) =>
        variance == 0 ? "—" : $"{(variance > 0 ? "+" : "")}{variance} min";
}

