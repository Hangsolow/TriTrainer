@page "/records"
@rendermode InteractiveServer
@inject ActivityApiClient ApiClient

<PageTitle>Records</PageTitle>

<h1 class="page-title">Personal Records</h1>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<section class="surface-card mb-4">
    <h2>Add Record</h2>
    <div class="d-flex flex-wrap gap-2 mb-3" aria-label="Quick record setup">
        <button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => ApplyDisciplinePreset(ActivityType.Run)">Run preset</button>
        <button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => ApplyDisciplinePreset(ActivityType.Cycle)">Cycle preset</button>
        <button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => ApplyDisciplinePreset(ActivityType.Swim)">Swim preset</button>
        @if (selectedTab.HasValue)
        {
            <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="ApplyFilterPreset">Use @selectedTab tab</button>
        }
        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick='() => ApplyDatePreset("today")'>Today</button>
        <button class="btn btn-sm btn-outline-secondary" type="button" @onclick='() => ApplyDatePreset("yesterday")'>Yesterday</button>
    </div>
    <form @onsubmit="CreateRecordFromSubmit" @onsubmit:preventDefault="true">
        <div class="row g-2">
            <div class="col-md-3">
                <label class="form-label" for="record-discipline">Discipline</label>
                <select id="record-discipline" class="form-select" @bind="discipline" @bind:after="ApplyDisciplineDefaultMetric">
                    @foreach (var value in Enum.GetValues<ActivityType>())
                    {
                        <option value="@value">@value</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" for="record-metric">Metric</label>
                <select id="record-metric" class="form-select" @bind="metric">
                    @foreach (var value in Enum.GetValues<PersonalRecordMetric>())
                    {
                        <option value="@value">@value</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label" for="record-value">Value</label>
                <input id="record-value" class="form-control" type="number" step="0.01" @bind="recordValue" />
            </div>
            <div class="col-md-3">
                <label class="form-label" for="record-date">Achieved On</label>
                <input id="record-date" class="form-control" type="date" @bind="achievedOnDate" />
            </div>
        </div>
        <button class="btn btn-primary mt-3" type="submit">Add Record</button>
    </form>
    <p class="text-muted small mt-2 mb-0">Tip: use Reuse on any row below to prefill this form for a faster update.</p>
</section>

<section class="surface-card">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <h2 class="mb-0">Record Insights</h2>
        <div class="tt-discipline-tabs" role="tablist" aria-label="Discipline filters">
            @foreach (var tab in tabs)
            {
                <button class="btn btn-sm @(selectedTab == tab.Value ? "btn-primary" : "btn-outline-primary")"
                        role="tab"
                        aria-selected="@(selectedTab == tab.Value)"
                        @onclick="() => SelectTab(tab.Value)">
                    @tab.Label
                </button>
            }
        </div>
    </div>

    @if (isLoading)
    {
        <p class="text-muted">Loading records...</p>
    }
    else if (records.Count == 0)
    {
        <p class="text-muted mb-2">No records yet. Add your first result to unlock discipline cards and trend views.</p>
        <button class="btn btn-sm btn-outline-primary" @onclick="StartFirstRecord">Start with a sample setup</button>
    }
    else
    {
        <div class="row g-3 mb-3">
            @foreach (var disciplineValue in Enum.GetValues<ActivityType>())
            {
                var best = GetBestCard(disciplineValue);
                var trend = GetTrendRecords(disciplineValue);
                <div class="col-lg-4">
                    <article class="tt-pr-card">
                        <h3>@DisciplineIcon(disciplineValue) @disciplineValue</h3>
                        @if (best is null)
                        {
                            <p class="text-muted mb-1">No personal best yet.</p>
                            <p class="text-muted mb-2">Add a record to start tracking.</p>
                        }
                        else
                        {
                            <p class="tt-pr-value mb-1">@best.Value</p>
                            <p class="mb-1">@best.Metric</p>
                            <p class="mb-2">@best.AchievedOn.ToString("yyyy-MM-dd")</p>
                            <p class="tt-pr-note mb-2">@GetNotesSnippet(best)</p>
                        }

                        <div>
                            <p class="tt-sparkline-label mb-1">Last 8 records</p>
                            <svg class="tt-sparkline" viewBox="0 0 100 30" preserveAspectRatio="none" aria-label="Trend for @disciplineValue">
                                <polyline points="@GetSparklinePoints(trend)" />
                            </svg>
                        </div>
                    </article>
                </div>
            }
        </div>

        <h3 class="h5">Record List</h3>
        var filteredRecords = SortedFilteredRecords().ToList();

        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
            <p class="text-muted small mb-0">Showing <strong>@filteredRecords.Count</strong> record(s). Filter: <strong>@FilterLabel()</strong>. Sort: <strong>@SortSummary()</strong>.</p>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ResetFilters">Reset filters</button>
        </div>

        <div class="table-responsive">
            <table class="table table-sm align-middle">
                <thead>
                    <tr>
                        <th>Discipline</th>
                        <th>Metric</th>
                        <th>
                            <button class="btn btn-link btn-sm p-0 tt-sort-btn" @onclick="() => SetSort(SortField.Value)">
                                Value @SortIndicator(SortField.Value)
                            </button>
                        </th>
                        <th>
                            <button class="btn btn-link btn-sm p-0 tt-sort-btn" @onclick="() => SetSort(SortField.Date)">
                                Date @SortIndicator(SortField.Date)
                            </button>
                        </th>
                        <th>Badge</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in filteredRecords)
                    {
                        <tr>
                            <td>@record.Discipline</td>
                            <td>@record.Metric</td>
                            <td>@record.Value</td>
                            <td>@record.AchievedOn.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (newRecordIds.Contains(record.Id))
                                {
                                    <span class="tt-pr-badge">New PR</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-secondary" aria-label="Reuse @record.Discipline @record.Metric record" @onclick="() => ReuseRecord(record)">Reuse</button>
                            </td>
                        </tr>
                    }
                    @if (filteredRecords.Count == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-muted">
                                No records in this discipline filter.
                                <button class="btn btn-sm btn-link" @onclick="ResetFilters">Show all</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private string? successMessage;
    private List<PersonalRecord> records = [];
    private List<PersonalRecord> personalBestRecords = [];
    private readonly HashSet<Guid> newRecordIds = [];
    private readonly Dictionary<Guid, string?> sourceActivityNotes = [];

    private readonly (ActivityType? Value, string Label)[] tabs =
    [
        (null, "All"),
        (ActivityType.Run, "Run"),
        (ActivityType.Cycle, "Cycle"),
        (ActivityType.Swim, "Swim")
    ];

    private ActivityType? selectedTab;

    private SortField currentSort = SortField.Date;
    private bool sortAscending;

    private ActivityType discipline = ActivityType.Run;
    private PersonalRecordMetric metric = PersonalRecordMetric.Fastest5k;
    private decimal recordValue = 1;
    private DateTime achievedOnDate = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await EnsureProfileAsync();
        await LoadRecordsAsync();
    }

    private async Task LoadRecordsAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            records = await ApiClient.GetRecordsAsync();
            personalBestRecords = await ApiClient.GetPersonalBestRecordsAsync();
            await LoadNotesAsync();
        }
        catch
        {
            // Absorb brief startup/readiness blips before surfacing an error.
            try
            {
                await Task.Delay(250);
                records = await ApiClient.GetRecordsAsync();
                personalBestRecords = await ApiClient.GetPersonalBestRecordsAsync();
                await LoadNotesAsync();
                errorMessage = null;
            }
            catch (Exception ex)
            {
                errorMessage = $"Failed to load records: {ex.Message}";
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateRecord()
    {
        errorMessage = null;
        successMessage = null;

        var achievedOn = DateOnly.FromDateTime(achievedOnDate.Date);

        if (recordValue <= 0)
        {
            errorMessage = "Value must be greater than 0.";
            return;
        }

        try
        {
            var created = await ApiClient.CreateRecordAsync(new CreatePersonalRecordRequest(
                discipline,
                metric,
                recordValue,
                achievedOn,
                null));

            if (created is not null)
            {
                newRecordIds.Add(created.Id);
            }

            successMessage = "Record added.";

            await LoadRecordsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to add record: {ex.Message}";
        }
    }

    private async Task EnsureProfileAsync()
    {
        var profile = await ApiClient.GetAthleteProfileAsync();
        if (profile is null)
        {
            await ApiClient.UpsertAthleteProfileAsync(new UpsertAthleteProfileRequest(
                "Triathlete",
                8,
                DateOnly.FromDateTime(DateTime.Today).AddDays(120)));
        }
    }

    private async Task LoadNotesAsync()
    {
        sourceActivityNotes.Clear();

        var monthlyKeys = personalBestRecords
            .Where(r => r.SourceActivityId.HasValue)
            .Select(r => (Year: r.AchievedOn.Year, Month: r.AchievedOn.Month))
            .Distinct()
            .ToList();

        foreach (var monthlyKey in monthlyKeys)
        {
            var activities = await ApiClient.GetActivitiesAsync(monthlyKey.Year, monthlyKey.Month);
            foreach (var activity in activities)
            {
                sourceActivityNotes[activity.Id] = activity.Notes;
            }
        }
    }

    private void SelectTab(ActivityType? tab)
    {
        selectedTab = tab;
        if (tab.HasValue)
        {
            ApplyDisciplinePreset(tab.Value);
        }
    }

    private void ResetFilters()
    {
        selectedTab = null;
        currentSort = SortField.Date;
        sortAscending = false;
    }

    private void ReuseRecord(PersonalRecord record)
    {
        discipline = record.Discipline;
        metric = record.Metric;
        recordValue = record.Value;
        achievedOnDate = record.AchievedOn.ToDateTime(TimeOnly.MinValue);
        successMessage = "Record values copied to form. Adjust and save when ready.";
    }

    private void StartFirstRecord()
    {
        discipline = selectedTab ?? ActivityType.Run;
        metric = RecordsWorkflowHelpers.DefaultMetricForDiscipline(discipline);

        recordValue = 1;
        achievedOnDate = DateTime.Today;
        successMessage = "Form prefilled for a first record entry.";
    }

    private Task CreateRecordFromSubmit()
    {
        return CreateRecord();
    }

    private void ApplyDisciplineDefaultMetric()
    {
        metric = RecordsWorkflowHelpers.DefaultMetricForDiscipline(discipline);
    }

    private void ApplyDisciplinePreset(ActivityType presetDiscipline)
    {
        discipline = presetDiscipline;
        metric = RecordsWorkflowHelpers.DefaultMetricForDiscipline(presetDiscipline);
        successMessage = $"{presetDiscipline} defaults loaded. Add value and save.";
    }

    private void ApplyFilterPreset()
    {
        if (selectedTab.HasValue)
        {
            ApplyDisciplinePreset(selectedTab.Value);
        }
    }

    private void ApplyDatePreset(string preset)
    {
        achievedOnDate = RecordsWorkflowHelpers.QuickDatePreset(preset, DateTime.Today);
    }

    private IEnumerable<PersonalRecord> SortedFilteredRecords()
    {
        var filtered = selectedTab.HasValue
            ? records.Where(r => r.Discipline == selectedTab.Value)
            : records;

        return (currentSort, sortAscending) switch
        {
            (SortField.Value, true) => filtered.OrderBy(r => r.Value).ThenByDescending(r => r.AchievedOn),
            (SortField.Value, false) => filtered.OrderByDescending(r => r.Value).ThenByDescending(r => r.AchievedOn),
            (SortField.Date, true) => filtered.OrderBy(r => r.AchievedOn).ThenByDescending(r => r.Value),
            _ => filtered.OrderByDescending(r => r.AchievedOn).ThenByDescending(r => r.Value)
        };
    }

    private void SetSort(SortField field)
    {
        if (currentSort == field)
        {
            sortAscending = !sortAscending;
            return;
        }

        currentSort = field;
        sortAscending = false;
    }

    private string SortIndicator(SortField field)
    {
        if (field != currentSort)
        {
            return "";
        }

        return sortAscending ? "↑" : "↓";
    }

    private string SortSummary() => (currentSort, sortAscending) switch
    {
        (SortField.Date, false) => "Newest first",
        (SortField.Date, true) => "Oldest first",
        (SortField.Value, false) => "Highest value first",
        _ => "Lowest value first"
    };

    private string FilterLabel() => selectedTab?.ToString() ?? "All disciplines";

    private PersonalRecord? GetBestCard(ActivityType disciplineValue) =>
        personalBestRecords
            .Where(r => r.Discipline == disciplineValue)
            .OrderByDescending(r => r.AchievedOn)
            .ThenByDescending(r => r.Value)
            .FirstOrDefault();

    private List<PersonalRecord> GetTrendRecords(ActivityType disciplineValue) =>
        records
            .Where(r => r.Discipline == disciplineValue)
            .OrderByDescending(r => r.AchievedOn)
            .Take(8)
            .OrderBy(r => r.AchievedOn)
            .ToList();

    private string GetSparklinePoints(List<PersonalRecord> trend)
    {
        if (trend.Count == 0)
        {
            return "0,30 100,30";
        }

        var minValue = trend.Min(t => t.Value);
        var maxValue = trend.Max(t => t.Value);
        var spread = maxValue - minValue;

        return string.Join(" ", trend.Select((item, index) =>
        {
            var x = trend.Count == 1 ? 50 : (decimal)index / (trend.Count - 1) * 100;
            var ratio = spread == 0 ? 0.5m : (item.Value - minValue) / spread;
            var y = 30 - (ratio * 30);
            return $"{x:0.##},{y:0.##}";
        }));
    }

    private string DisciplineIcon(ActivityType disciplineValue) => disciplineValue switch
    {
        ActivityType.Run => "🏃",
        ActivityType.Cycle => "🚴",
        ActivityType.Swim => "🏊",
        _ => ""
    };

    private string GetNotesSnippet(PersonalRecord record)
    {
        if (!record.SourceActivityId.HasValue)
        {
            return "Notes: no linked activity.";
        }

        if (!sourceActivityNotes.TryGetValue(record.SourceActivityId.Value, out var note) || string.IsNullOrWhiteSpace(note))
        {
            return "Notes: none available.";
        }

        var trimmed = note.Trim();
        var snippet = trimmed.Length > 48 ? $"{trimmed[..48]}..." : trimmed;
        return $"Notes: {snippet}";
    }

    private enum SortField
    {
        Date,
        Value
    }
}
