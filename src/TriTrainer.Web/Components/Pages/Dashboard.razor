@page "/"
@page "/dashboard"
@rendermode InteractiveServer
@inject ActivityApiClient ApiClient

<PageTitle>Dashboard</PageTitle>

<header class="tt-dashboard-header">
    <h1 class="page-title mb-1">Dashboard</h1>
    <p class="tt-dashboard-subtitle mb-0">Review your current training status and act on the most important guidance first.</p>
</header>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <p class="text-muted">Loading dashboard...</p>
}
else
{
    var quickPath = DashboardRecommendationHelpers.ResolveDailyCheckInQuickPath(
        activeGoal is not null,
        currentPlan?.Id,
        currentPlan?.StartDate,
        nextSession?.Date,
        DateOnly.FromDateTime(DateTime.Today));

    <div class="tt-dashboard-kpis" aria-label="Dashboard highlights">
        <article class="tt-kpi-card">
            <p class="tt-kpi-label">Active plan</p>
            <p class="tt-kpi-value mb-0">@(currentPlan is null ? "No active plan" : currentPlan.Name)</p>
        </article>
        <article class="tt-kpi-card">
            <p class="tt-kpi-label">Weekly compliance</p>
            <p class="tt-kpi-value mb-0 @DashboardRecommendationHelpers.ComplianceBandClass(weeklyProgress?.Totals.CompliancePercent)">@DashboardRecommendationHelpers.ComplianceBandLabel(weeklyProgress?.Totals.CompliancePercent)</p>
        </article>
        <article class="tt-kpi-card">
            <p class="tt-kpi-label">Next session</p>
            <p class="tt-kpi-value mb-0">@(nextSession is null ? "Not scheduled" : $"{DisciplineIcon(nextSession.Discipline)} {nextSession.Discipline} {nextSession.SessionType}")</p>
        </article>
    </div>

    <section class="surface-card tt-checkin-quickpath" aria-label="Daily check-in quick path">
        <div>
            <h2 class="mb-1">Daily check-in</h2>
            <p class="tt-section-note mb-0">@quickPath.Description</p>
        </div>
        <a class="btn btn-primary" href="@quickPath.Href">@quickPath.Label</a>
    </section>

    <div class="grid-cards tt-dashboard-grid">
        <section class="surface-card tt-card-priority">
            <h2>Recommendations</h2>
            <p class="tt-section-note">Start here for this week&apos;s highest-impact actions.</p>
            @if (recommendationInsights is null)
            {
                <p class="text-muted mb-0">No recommendation insights available yet.</p>
            }
            else
            {
                var insights = DashboardRecommendationHelpers.InsightsOrEmpty(recommendationInsights);
                @if (insights.Count == 0)
                {
                    <p class="text-muted mb-0">You are on track. Check back after your next workout.</p>
                }
                else
                {
                    <p class="mb-2 text-muted">Based on your @DashboardRecommendationHelpers.TrendWindowLabel(recommendationInsights.WeeksEvaluated).</p>
                    <div class="tt-reco-list" role="list">
                        @foreach (var insight in insights)
                        {
                            <article class="tt-reco-card" role="listitem">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <h3 class="tt-reco-title mb-1">@insight.Title</h3>
                                    <span class="tt-severity-badge @DashboardRecommendationHelpers.SeverityBadgeClass(insight.Severity)">@DashboardRecommendationHelpers.SeverityLabel(insight.Severity)</span>
                                </div>
                                <p class="mb-1">@insight.Message</p>
                                <p class="tt-reco-action mb-2"><strong>Action:</strong> @insight.Action</p>
                                <a class="btn btn-sm btn-outline-primary" href="@DashboardRecommendationHelpers.RecommendationHrefWithContext(insight.Code, currentPlan?.Id, currentPlan?.StartDate)">@DashboardRecommendationHelpers.RecommendationCtaLabel(insight.Code)</a>
                            </article>
                        }
                    </div>
                }
            }
        </section>

        <section class="surface-card tt-card-priority">
            <h2>Weekly Compliance</h2>
            <p class="tt-section-note">Compare planned and completed minutes for your current training week.</p>
            @if (weeklyProgress is null)
            {
                <p class="text-muted mb-0">No progress data yet for the selected plan week.</p>
            }
            else
            {
                <dl class="tt-stat-list mb-0">
                    <div>
                        <dt>Total planned</dt>
                        <dd>@weeklyProgress.Totals.PlannedMinutes min</dd>
                    </div>
                    <div>
                        <dt>Total completed</dt>
                        <dd>@weeklyProgress.Totals.CompletedMinutes min</dd>
                    </div>
                    <div>
                        <dt>Compliance</dt>
                        <dd class="@DashboardRecommendationHelpers.ComplianceBandClass(weeklyProgress.Totals.CompliancePercent)">@weeklyProgress.Totals.CompliancePercent%</dd>
                    </div>
                </dl>
            }
        </section>

        <section class="surface-card">
            <h2>Profile</h2>
            @if (profile is null)
            {
                <p class="text-muted">No athlete profile found.</p>
            }
            else
            {
                <p class="mb-1"><strong>@profile.DisplayName</strong></p>
                <p class="mb-1">Weekly hours available: @profile.WeeklyHoursAvailable</p>
                <p class="mb-0">Primary event: @(profile.PrimaryEventDate?.ToString("yyyy-MM-dd") ?? "Not set")</p>
            }
        </section>

        <section class="surface-card">
            <h2>Active Goal</h2>
            @if (activeGoal is null)
            {
                <p class="text-muted">No active goal yet.</p>
                <a class="btn btn-sm btn-outline-primary" href="goals">Create goal</a>
            }
            else
            {
                <p class="mb-1"><strong>@activeGoal.GoalType</strong></p>
                <p class="mb-1">Discipline: @(activeGoal.Discipline?.ToString() ?? "Any")</p>
                <p class="mb-0">Target date: @activeGoal.TargetDate.ToString("yyyy-MM-dd")</p>
            }
        </section>

        <section class="surface-card">
            <h2>Current Plan</h2>
            @if (currentPlan is null)
            {
                <p class="text-muted">No plan available yet.</p>
                <a class="btn btn-sm btn-outline-primary" href="plans">Create plan</a>
            }
            else
            {
                <p class="mb-1"><strong>@currentPlan.Name</strong> (@currentPlan.Status)</p>
                <p class="mb-0">@currentPlan.StartDate.ToString("yyyy-MM-dd") to @currentPlan.EndDate.ToString("yyyy-MM-dd")</p>
                <a class="btn btn-sm btn-outline-primary mt-3" href="@($"progress?planId={currentPlan.Id}&weekStart={currentPlan.StartDate:yyyy-MM-dd}")">Open weekly progress</a>
            }
        </section>

        <section class="surface-card">
            <h2>Rolling 4-Week Compliance</h2>
            <p class="tt-section-note">Trend view of your last four weekly compliance scores.</p>
            @if (progressSummary is null || progressSummary.WeeksSummary.Count == 0)
            {
                <p class="text-muted mb-0">No compliance summary available.</p>
            }
            else
            {
                <div class="tt-compliance-chart" role="img" aria-label="4 week compliance chart">
                    @foreach (var week in progressSummary.WeeksSummary)
                    {
                        var height = Math.Clamp((double)week.CompliancePercent, 0, 100);
                        <div class="tt-compliance-col">
                            <div class="tt-compliance-bar @ComplianceBarClass(week.CompliancePercent)" style="height:@height%"></div>
                            <span class="tt-compliance-week">@week.WeekStartDate.ToString("MM/dd")</span>
                        </div>
                    }
                </div>
                <p class="mb-0 mt-2"><strong>Overall:</strong> @progressSummary.OverallCompliancePercent%</p>
            }
        </section>

        <section class="surface-card">
            <h2>Streaks</h2>
            @if (progressSummary is null)
            {
                <p class="text-muted">No streak data yet.</p>
            }
            else
            {
                <div class="tt-streak-grid">
                    <div>
                        <p class="mb-1 text-muted">Current</p>
                        <p class="tt-streak-value mb-0">@progressSummary.CurrentStreakWeeks weeks</p>
                    </div>
                    <div>
                        <p class="mb-1 text-muted">Longest</p>
                        <p class="tt-streak-value mb-0">@progressSummary.LongestStreakWeeks weeks</p>
                    </div>
                </div>
            }
        </section>

        <section class="surface-card">
            <h2>Next Planned Session</h2>
            <p class="tt-section-note">Your upcoming workout in the active plan.</p>
            @if (nextSession is null)
            {
                <p class="text-muted mb-0">No upcoming session found in the current plan.</p>
            }
            else
            {
                <p class="mb-1"><strong>@DisciplineIcon(nextSession.Discipline) @nextSession.Discipline</strong></p>
                <p class="mb-1">@nextSession.SessionType on @nextSession.Date.ToString("dddd")</p>
                <p class="mb-0">@nextSession.PlannedDurationMinutes minutes</p>
            }
        </section>
    </div>
}

@code {
    private bool isLoading = true;
    private string? errorMessage;

    private AthleteProfile? profile;
    private Goal? activeGoal;
    private PlanSummary? currentPlan;
    private WeeklyProgressResponse? weeklyProgress;
    private ProgressSummaryResponse? progressSummary;
    private RecommendationInsightsResponse? recommendationInsights;
    private NextSessionViewModel? nextSession;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            profile = await EnsureProfileAsync();
            if (profile is null)
            {
                return;
            }

            var goals = await ApiClient.GetGoalsAsync();
            activeGoal = goals.FirstOrDefault(g => g.Status == GoalStatus.Active)
                ?? goals.FirstOrDefault(g => g.Status == GoalStatus.Draft);

            var plans = await ApiClient.GetPlansAsync();
            currentPlan = plans.FirstOrDefault(p => p.Status == PlanStatus.Active)
                ?? plans.FirstOrDefault();

            if (currentPlan is not null)
            {
                weeklyProgress = await ApiClient.GetWeeklyProgressAsync(currentPlan.Id, currentPlan.StartDate);
                progressSummary = await ApiClient.GetProgressSummaryAsync(4);

                var planDetail = await ApiClient.GetPlanAsync(currentPlan.Id);
                nextSession = BuildNextSession(planDetail);
            }

            recommendationInsights = await ApiClient.GetRecommendationInsightsAsync(4);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load dashboard: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<AthleteProfile?> EnsureProfileAsync()
    {
        var existing = await ApiClient.GetAthleteProfileAsync();
        if (existing is not null)
        {
            return existing;
        }

        return await ApiClient.UpsertAthleteProfileAsync(new UpsertAthleteProfileRequest(
            "Triathlete",
            8,
            DateOnly.FromDateTime(DateTime.Today).AddDays(120)));
    }

    private static string ComplianceBarClass(decimal pct) =>
        pct >= 90 ? "tt-progress-high" : pct >= 70 ? "tt-progress-mid" : "tt-progress-low";

    private static string DisciplineIcon(ActivityType discipline) => discipline switch
    {
        ActivityType.Run => "🏃",
        ActivityType.Cycle => "🚴",
        ActivityType.Swim => "🏊",
        _ => ""
    };

    private static NextSessionViewModel? BuildNextSession(PlanDetail? plan)
    {
        if (plan is null)
        {
            return null;
        }

        var today = DateOnly.FromDateTime(DateTime.Today);

        return plan.Weeks
            .SelectMany(week => week.Sessions.Select(session =>
            {
                var offset = ((int)session.DayOfWeek - (int)DayOfWeek.Monday + 7) % 7;
                var sessionDate = week.WeekStartDate.AddDays(offset);
                return new NextSessionViewModel(session.Discipline, session.SessionType, sessionDate, session.PlannedDurationMinutes);
            }))
            .Where(s => s.Date >= today)
            .OrderBy(s => s.Date)
            .ThenBy(s => s.Discipline)
            .FirstOrDefault();
    }

    private sealed record NextSessionViewModel(ActivityType Discipline, SessionType SessionType, DateOnly Date, int PlannedDurationMinutes);
}
