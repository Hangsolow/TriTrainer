@ApiService_HostAddress = http://localhost:5398

### Get all activities for a month
GET {{ApiService_HostAddress}}/activities?year=2026&month=4
Accept: application/json

###

### Get all activities (no filter)
GET {{ApiService_HostAddress}}/activities
Accept: application/json

###

### Add a run activity
POST {{ApiService_HostAddress}}/activities
Content-Type: application/json

{
  "date": "2026-04-30",
  "type": "Run",
  "durationMinutes": 45,
  "notes": "Easy morning run"
}

###

### Add a cycle activity
POST {{ApiService_HostAddress}}/activities
Content-Type: application/json

{
  "date": "2026-04-29",
  "type": "Cycle",
  "durationMinutes": 90,
  "notes": "Long ride"
}

###

### Add a swim activity
POST {{ApiService_HostAddress}}/activities
Content-Type: application/json

{
  "date": "2026-04-28",
  "type": "Swim",
  "durationMinutes": 30,
  "notes": "500m intervals"
}

###

### Delete an activity (replace id with a real GUID)
DELETE {{ApiService_HostAddress}}/activities/00000000-0000-0000-0000-000000000000

###

### Upsert athlete profile (required for /v1 endpoints)
PUT {{ApiService_HostAddress}}/v1/athlete-profile
Content-Type: application/json

{
  "displayName": "Triathlete",
  "weeklyHoursAvailable": 8,
  "primaryEventDate": "2026-09-20"
}

###

### Create personal record
POST {{ApiService_HostAddress}}/v1/records
Content-Type: application/json

{
  "discipline": "Run",
  "metric": "Fastest5k",
  "value": 24.5,
  "achievedOn": "2026-05-20",
  "sourceActivityId": null
}

###

### List all personal records
GET {{ApiService_HostAddress}}/v1/records
Accept: application/json

###

### List records for one discipline
GET {{ApiService_HostAddress}}/v1/records?discipline=Run
Accept: application/json

###

### List personal-best records across disciplines
GET {{ApiService_HostAddress}}/v1/records/personal-best
Accept: application/json

###

### List personal-best record for a discipline
GET {{ApiService_HostAddress}}/v1/records/personal-best?discipline=Run
Accept: application/json

###

### Progress summary (default weeks=4)
GET {{ApiService_HostAddress}}/v1/progress/summary
Accept: application/json

###

### Progress summary (custom weeks)
GET {{ApiService_HostAddress}}/v1/progress/summary?weeks=8
Accept: application/json

###
